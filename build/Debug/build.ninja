  COMMAND = cd /Users/work/dev/vapor_track/build/Debug && /opt/homebrew/bin/cmake --regenerate-during-build -S/Users/work/dev/vapor_track -B/Users/work/dev/vapor_track/build/Debug
  DESC = Running CMake to regenerate build system...
  pool = console
  restat = 1

build rebuild_cache: phony CMakeFiles/rebuild_cache.util


#############################################
# Custom command for CMakeFiles/flash

build CMakeFiles/flash | ${cmake_ninja_workdir}CMakeFiles/flash: CUSTOM_COMMAND vapor_track.elf || cmake/stm32cubemx/FreeRTOS cmake/stm32cubemx/STM32_Drivers vapor_track.elf
  COMMAND = cd /Users/work/dev/vapor_track/build/Debug && st-flash --connect-under-reset --reset write vapor_track.bin 0x08000000
  DESC = Flashing firmware to target hardware...

